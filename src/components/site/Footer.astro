---
import { GraduationCap } from "lucide-react";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border/60 bg-background">
  <div class="mx-auto grid max-w-(--container-2xl) gap-10 px-4 py-12 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-semibold">
        <span class="flex h-6 w-6 items-center justify-center rounded-md bg-primary/15 text-primary">
          <GraduationCap className="h-3.5 w-3.5" />
        </span>
        <span>learn<span class="text-primary">.msp.au</span></span>
      </div>
      <p class="mt-3 max-w-md text-sm text-muted-foreground">
        Free, opinionated training for MSP technicians — vendor product courses
        across Beginner, Intermediate, and Advanced tiers. No accounts. No
        tracking. Just the critical path.
      </p>
    </div>
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        Learn
      </h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/vendors/">Vendors</a></li>
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/concepts/">Concepts</a></li>
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/paths/">Learning paths</a></li>
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/glossary/">Glossary</a></li>
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/curate/">My stack</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        Site
      </h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/about/">About</a></li>
        <li><a class="text-muted-foreground transition-colors hover:text-foreground" href="/settings/">Settings & data</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border/60">
    <div class="mx-auto flex max-w-(--container-2xl) items-center justify-between px-4 py-5 text-xs text-muted-foreground sm:px-6">
      <span>&copy; {year} learn.msp.au</span>
      <span>Built static. Cookieless. Free forever.</span>
    </div>
  </div>
</footer>
