---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/site/Breadcrumb.astro";
import { Badge } from "@/components/ui/badge";
import { Clock, ArrowLeft, ArrowRight, Trophy } from "lucide-react";

import { Term } from "@/components/learning/Term";
import { Callout } from "@/components/learning/Callout";
import { Kbd } from "@/components/learning/Kbd";
import {
  AnnotatedScreenshot,
  Hotspot,
} from "@/components/learning/AnnotatedScreenshot";
import { StepThrough, Step } from "@/components/learning/StepThrough";
import { DecisionTree } from "@/components/learning/DecisionTree";
import { Checkpoint } from "@/components/learning/Checkpoint";
import { LessonProgress } from "@/components/learning/LessonProgress";
import ListenButton from "@/components/learning/ListenButton";
import MermaidLoader from "@/components/learning/MermaidLoader.astro";
import DraftBanner from "@/components/learning/DraftBanner.astro";
import {
  courseUrl,
  courseUrlSuffix,
  levelLabel,
} from "@/lib/courseRoute";
import { isPublic } from "@/lib/dev-only";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons");
  const courses = (await getCollection("courses")).filter(isPublic);
  const vendors = (await getCollection("vendors")).filter(isPublic);
  const conceptSlugs = new Set(
    vendors.filter((v) => v.data.kind === "concept").map((v) => v.data.slug),
  );

  const paths: any[] = [];
  for (const l of lessons) {
    const ref = l.data.vendor;
    const vendorSlug = typeof ref === "string" ? ref : ref?.id;
    if (!vendorSlug || !conceptSlugs.has(vendorSlug)) continue;
    const owningCourses = courses.filter(
      (c) =>
        (typeof c.data.vendor === "string"
          ? c.data.vendor
          : c.data.vendor?.id) === vendorSlug &&
        c.data.lessons.includes(l.data.slug),
    );
    for (const c of owningCourses) {
      paths.push({
        params: {
          concept: vendorSlug,
          course: courseUrlSuffix(c),
          lesson: l.data.slug,
        },
        props: { lesson: l, course: c, courses },
      });
    }
  }
  return paths;
}

const { lesson, course } = Astro.props;
const { concept: vendorParam } = Astro.params;
const level = lesson.data.level as "l1" | "l2" | "l3";

const vendors = (await getCollection("vendors")).filter(isPublic);
const vendor = vendors.find((v) => v.data.slug === vendorParam)!;

const allLessons = await getCollection("lessons");
const ordered = course
  ? course.data.lessons
      .map((slug: string) =>
        allLessons.find(
          (l) =>
            l.data.slug === slug &&
            (typeof l.data.vendor === "string"
              ? l.data.vendor
              : l.data.vendor?.id) === vendor.data.slug,
        ),
      )
      .filter(Boolean)
  : [];

const idx = ordered.findIndex((l: any) => l && l.data.slug === lesson.data.slug);
const prev = idx > 0 ? ordered[idx - 1] : null;
const next = idx >= 0 && idx + 1 < ordered.length ? ordered[idx + 1] : null;
const isLast = idx === ordered.length - 1;
const finalQuizSlug = course?.data.quiz ?? null;

const { Content } = await render(lesson);

const components = {
  Term,
  Callout,
  Kbd,
  AnnotatedScreenshot,
  Hotspot,
  StepThrough,
  Step,
  DecisionTree,
  Checkpoint,
};

const courseBase = courseUrl(course, vendor);
---

<BaseLayout
  title={`${lesson.data.title}, ${vendor.data.name} ${levelLabel[level]}`}
  description={lesson.data.summary}
>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-8">
    <Breadcrumb
      items={[
        { href: "/", label: "Home" },
        { href: "/concepts/", label: "Concepts" },
        { href: `/concepts/${vendor.data.slug}/`, label: vendor.data.name },
        { href: courseBase, label: course.data.title },
        { label: lesson.data.title },
      ]}
    />

    <header class="mt-6 mb-8 border-b border-border pb-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <Badge variant={level as "l1" | "l2" | "l3"} className="text-[10px] uppercase tracking-widest">
          {levelLabel[level]}
        </Badge>
        <span class="text-xs text-muted-foreground">
          Lesson {idx + 1} of {ordered.length}
        </span>
        <span class="text-xs text-muted-foreground">·</span>
        <span class="inline-flex items-center gap-1 text-xs text-muted-foreground">
          <Clock className="h-3 w-3" /> ~{lesson.data.estimatedMinutes} min
        </span>
        <ListenButton client:idle className="ml-auto" />
      </div>
      {lesson.data.draft && <DraftBanner reason={lesson.data.draftReason} />}
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
        {lesson.data.title}
      </h1>
      <p class="mt-3 text-lg text-foreground/90 leading-relaxed">
        {lesson.data.summary}
      </p>
    </header>

    <div class="lesson-prose" data-tts-root>
      <Content components={components} />
    </div>

    <MermaidLoader />

    <LessonProgress
      lessonSlug={lesson.data.slug}
      vendor={vendor.data.slug}
      level={level}
      nextHref={
        next
          ? `${courseBase}${(next as any).data.slug}/`
          : isLast && finalQuizSlug
            ? `${courseBase}quiz/`
            : null
      }
      nextLabel={
        next ? "Next lesson" : isLast && finalQuizSlug ? "Take the final quiz" : null
      }
      client:idle
    />

    <nav
      class="mt-8 grid gap-3 sm:grid-cols-2"
      aria-label="Lesson navigation"
    >
      {prev && (
        <a
          href={`${courseBase}${(prev as any).data.slug}/`}
          class="group flex items-center gap-3 rounded-lg border border-border bg-card p-4 transition-colors hover:border-primary/40"
          data-astro-prefetch
        >
          <ArrowLeft className="h-4 w-4 text-muted-foreground transition-transform group-hover:-translate-x-0.5 group-hover:text-primary" />
          <div class="min-w-0">
            <div class="text-[10px] uppercase tracking-widest text-muted-foreground">
              Previous
            </div>
            <div class="truncate text-sm font-medium group-hover:text-primary">
              {(prev as any).data.title}
            </div>
          </div>
        </a>
      )}
      {next ? (
        <a
          href={`${courseBase}${(next as any).data.slug}/`}
          class="group ml-auto flex items-center gap-3 rounded-lg border border-border bg-card p-4 transition-colors hover:border-primary/40 sm:ml-0 sm:justify-end"
          data-astro-prefetch
        >
          <div class="min-w-0 text-right">
            <div class="text-[10px] uppercase tracking-widest text-muted-foreground">
              Next
            </div>
            <div class="truncate text-sm font-medium group-hover:text-primary">
              {(next as any).data.title}
            </div>
          </div>
          <ArrowRight className="h-4 w-4 text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-primary" />
        </a>
      ) : (
        finalQuizSlug && (
          <a
            href={`${courseBase}quiz/`}
            class="group ml-auto flex items-center gap-3 rounded-lg border border-primary/40 bg-primary/5 p-4 transition-colors hover:border-primary hover:bg-primary/10 sm:ml-0 sm:justify-end"
            data-astro-prefetch
          >
            <div class="min-w-0 text-right">
              <div class="text-[10px] uppercase tracking-widest text-muted-foreground">
                You're at the end
              </div>
              <div class="truncate text-sm font-medium text-primary">
                Take the final quiz
              </div>
            </div>
            <Trophy className="h-4 w-4 text-primary" />
          </a>
        )
      )}
    </nav>
  </article>
</BaseLayout>
