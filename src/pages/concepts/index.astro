---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/site/Breadcrumb.astro";
import { Badge } from "@/components/ui/badge";
import { isPublic } from "@/lib/dev-only";

const vendors = (await getCollection("vendors"))
  .filter(isPublic)
  .filter((v) => v.data.kind === "concept")
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const courses = (await getCollection("courses")).filter(isPublic);

function vendorLevels(vendorSlug: string) {
  const vc = courses.filter((c) => {
    const ref = c.data.vendor;
    const slug = typeof ref === "string" ? ref : ref?.id;
    return slug === vendorSlug && c.data.status === "live";
  });
  return new Set(vc.map((c) => c.data.level));
}

function hasLiveCourse(vendorSlug: string) {
  return courses.some((c) => {
    const ref = c.data.vendor;
    const slug = typeof ref === "string" ? ref : ref?.id;
    return slug === vendorSlug && c.data.status === "live";
  });
}

const isLiveConcept = (v: (typeof vendors)[number]) =>
  v.data.status === "live" && hasLiveCourse(v.data.slug);

const liveVendors = vendors.filter(isLiveConcept);
const plannedVendors = vendors.filter((v) => !isLiveConcept(v));

const levelLabel: Record<"l1" | "l2" | "l3", string> = {
  l1: "Beginner",
  l2: "Intermediate",
  l3: "Advanced",
};
---

<BaseLayout
  title="Concepts & fundamentals"
  description="Vendor-neutral fundamentals every MSP technician needs: DNS, networking, identity, certificates."
>
  <div class="mx-auto max-w-(--container-2xl) px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ href: "/", label: "Home" }, { label: "Concepts" }]} />

    <header class="mt-6 mb-10">
      <h1 class="text-4xl font-semibold tracking-tight">Concepts &amp; fundamentals</h1>
      <p class="mt-3 max-w-2xl text-muted-foreground text-lg">
        The skills that don't belong to one vendor. DNS, networking, identity,
        certificates: the layers underneath every customer ticket. Three
        layered courses each, Beginner to Advanced.
      </p>
    </header>

    {
      vendors.length === 0 && (
        <p class="text-sm text-muted-foreground">More concept tracks coming soon.</p>
      )
    }

    {
      liveVendors.length > 0 && (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {liveVendors.map((v) => {
            const live = vendorLevels(v.data.slug);
            return (
              <a
                href={`/concepts/${v.data.slug}/`}
                class="group flex flex-col rounded-xl border border-border bg-card p-5 transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-lg"
                data-astro-prefetch
                data-curate-vendor={v.data.slug}
              >
                <div class="flex items-start justify-between gap-2">
                  <div
                    class="flex h-10 w-10 items-center justify-center rounded-md text-base font-semibold"
                    style={`background:${v.data.accent}; color: oklch(0.14 0.01 260);`}
                  >
                    {v.data.name[0]}
                  </div>
                  <Badge
                    variant="outline"
                    className="text-[10px] uppercase tracking-widest"
                  >
                    Concept
                  </Badge>
                </div>
                <h2 class="mt-4 text-lg font-semibold tracking-tight group-hover:text-primary">
                  {v.data.name}
                </h2>
                <p class="mt-1 text-sm text-muted-foreground">{v.data.tagline}</p>
                <p class="mt-3 text-sm text-foreground/80 line-clamp-3">
                  {v.data.summary}
                </p>
                <div class="mt-5 flex flex-wrap gap-1.5">
                  {(["l1", "l2", "l3"] as const).map((lvl) => (
                    <Badge
                      variant={live.has(lvl) ? lvl : "outline"}
                      className="text-[10px] uppercase tracking-widest"
                    >
                      {levelLabel[lvl]} {live.has(lvl) ? "✓" : "—"}
                    </Badge>
                  ))}
                </div>
              </a>
            );
          })}
        </div>
      )
    }

    {
      plannedVendors.length > 0 && (
        <section aria-labelledby="planned-concepts-heading" class={liveVendors.length > 0 ? "mt-14" : ""}>
          <h2
            id="planned-concepts-heading"
            class="mb-4 text-sm font-semibold uppercase tracking-widest text-muted-foreground"
          >
            Coming soon
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {plannedVendors.map((v) => {
              const live = vendorLevels(v.data.slug);
              return (
                <a
                  href={`/concepts/${v.data.slug}/`}
                  class="group flex flex-col rounded-xl border border-dashed border-border bg-card/60 p-5 transition-all hover:border-primary/40 hover:bg-card"
                  data-astro-prefetch
                  data-curate-vendor={v.data.slug}
                >
                  <div class="flex items-start justify-between gap-2">
                    <div
                      class="flex h-10 w-10 items-center justify-center rounded-md text-base font-semibold opacity-70"
                      style={`background:${v.data.accent}; color: oklch(0.14 0.01 260);`}
                    >
                      {v.data.name[0]}
                    </div>
                    <Badge variant="outline" className="text-[10px] uppercase tracking-widest">
                      Planned
                    </Badge>
                  </div>
                  <h2 class="mt-4 text-lg font-semibold tracking-tight text-muted-foreground group-hover:text-primary">
                    {v.data.name}
                  </h2>
                  <p class="mt-1 text-sm text-muted-foreground">{v.data.tagline}</p>
                  <p class="mt-3 text-sm text-foreground/80 line-clamp-3">
                    {v.data.summary}
                  </p>
                  <div class="mt-5 flex flex-wrap gap-1.5">
                    {(["l1", "l2", "l3"] as const).map((lvl) => (
                      <Badge
                        variant={live.has(lvl) ? lvl : "outline"}
                        className="text-[10px] uppercase tracking-widest"
                      >
                        {levelLabel[lvl]} {live.has(lvl) ? "✓" : "—"}
                      </Badge>
                    ))}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
