---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/site/Breadcrumb.astro";
import { CurationPanel, type VendorOption } from "@/components/curate/CurationPanel";

const allVendors = (await getCollection("vendors")).sort(
  (a, b) => a.data.order - b.data.order,
);
const allCourses = await getCollection("courses");
const allLessons = await getCollection("lessons");

function liveLevelsFor(vendorSlug: string): ("l1" | "l2" | "l3")[] {
  const out: ("l1" | "l2" | "l3")[] = [];
  for (const lvl of ["l1", "l2", "l3"] as const) {
    const course = allCourses.find((c) => {
      const ref = c.data.vendor;
      const slug = typeof ref === "string" ? ref : ref?.id;
      return slug === vendorSlug && c.data.level === lvl && c.data.status === "live";
    });
    if (!course) continue;
    const hasNonDraft = course.data.lessons.some((lessonSlug) => {
      const l = allLessons.find(
        (ls) =>
          ls.data.slug === lessonSlug &&
          (typeof ls.data.vendor === "string"
            ? ls.data.vendor
            : ls.data.vendor?.id) === vendorSlug,
      );
      return l && !l.data.draft;
    });
    if (hasNonDraft) out.push(lvl);
  }
  return out;
}

const vendorOptions: VendorOption[] = allVendors.map((v) => ({
  slug: v.data.slug,
  name: v.data.name,
  tagline: v.data.tagline,
  status: v.data.status,
  liveLevels: liveLevelsFor(v.data.slug),
}));
---

<BaseLayout
  title="Curate your stack"
  description="Filter learn.msp.au to just the products your MSP uses. Save the URL, share it with your team."
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ href: "/", label: "Home" }, { label: "Curate" }]} />

    <header class="mt-6 mb-8">
      <h1 class="text-4xl font-semibold tracking-tight">Curate your stack</h1>
      <p class="mt-3 max-w-2xl text-muted-foreground text-lg">
        Pick the vendors and levels your MSP actually uses. The site filters to
        just those products. Share the resulting URL or JSON with your team —
        their browsers will offer to apply it.
      </p>
      <p class="mt-2 text-xs text-muted-foreground">
        Stored locally in your browser. No accounts. No tracking.
      </p>
    </header>

    <CurationPanel client:load vendors={vendorOptions} />
  </div>
</BaseLayout>
