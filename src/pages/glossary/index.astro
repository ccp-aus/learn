---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/site/Breadcrumb.astro";

const terms = (await getCollection("glossary")).sort((a, b) =>
  a.data.term.localeCompare(b.data.term),
);

// Group by first letter for an alpha index
const groups = new Map<string, typeof terms>();
for (const t of terms) {
  const letter = t.data.term[0].toUpperCase();
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push(t);
}
const letters = Array.from(groups.keys()).sort();
---

<BaseLayout
  title="Glossary"
  description="MSP terms, vendor jargon, and core concepts — defined in plain language."
>
  <div class="mx-auto max-w-(--container-2xl) px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ href: "/", label: "Home" }, { label: "Glossary" }]} />

    <header class="mt-6 mb-10">
      <h1 class="text-4xl font-semibold tracking-tight">Glossary</h1>
      <p class="mt-3 max-w-2xl text-muted-foreground text-lg">
        The MSP world is acronym-heavy. Hover any underlined term anywhere on
        the site for a quick definition; the full entries live here.
      </p>
    </header>

    <nav aria-label="Jump to letter" class="mb-8 flex flex-wrap gap-1.5">
      {
        letters.map((l) => (
          <a
            href={`#${l}`}
            class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border bg-card text-sm font-medium text-muted-foreground transition-colors hover:bg-primary/15 hover:text-primary"
          >
            {l}
          </a>
        ))
      }
    </nav>

    <div class="space-y-12">
      {
        letters.map((letter) => (
          <section id={letter} aria-labelledby={`heading-${letter}`}>
            <h2
              id={`heading-${letter}`}
              class="mb-4 text-xs font-semibold uppercase tracking-widest text-muted-foreground"
            >
              {letter}
            </h2>
            <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {groups.get(letter)!.map((t) => (
                <li>
                  <a
                    href={`/glossary/${t.data.slug}/`}
                    class="group block rounded-lg border border-border bg-card p-4 transition-colors hover:border-primary/40 hover:bg-card/70"
                  >
                    <div class="font-semibold tracking-tight group-hover:text-primary">
                      {t.data.term}
                    </div>
                    <p class="mt-1 line-clamp-2 text-sm text-muted-foreground">
                      {t.data.short}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
