---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/site/Breadcrumb.astro";
import { Map } from "lucide-react";
import { isPublic } from "@/lib/dev-only";

const paths = (await getCollection("paths")).filter(isPublic);
---

<BaseLayout
  title="Learning paths"
  description="Curated cross-vendor sequences for common MSP roles."
>
  <div class="mx-auto max-w-(--container-2xl) px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ href: "/", label: "Home" }, { label: "Learning paths" }]} />

    <header class="mt-6 mb-10">
      <h1 class="text-4xl font-semibold tracking-tight">Learning paths</h1>
      <p class="mt-3 max-w-2xl text-muted-foreground text-lg">
        Curated sequences across vendors. Pick one that matches where you are
        in your MSP career and follow it end-to-end.
      </p>
    </header>

    {paths.length === 0 ? (
      <p class="text-sm text-muted-foreground">
        No paths yet — check back soon.
      </p>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {paths.map((p) => (
          <a
            href={`/paths/${p.data.slug}/`}
            class="group flex flex-col rounded-xl border border-border bg-card p-6 transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-lg"
            data-astro-prefetch
          >
            <Map className="h-5 w-5 text-primary" />
            <h2 class="mt-4 text-lg font-semibold tracking-tight group-hover:text-primary">
              {p.data.title}
            </h2>
            <p class="mt-2 text-sm text-muted-foreground line-clamp-3">
              {p.data.summary}
            </p>
            <div class="mt-4 flex items-center justify-between text-xs text-muted-foreground">
              <span>For: {p.data.audience}</span>
              <span>{p.data.courses.length} courses</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
