---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/site/Breadcrumb.astro";
import { Badge } from "@/components/ui/badge";
import { Quiz } from "@/components/learning/Quiz";

export async function getStaticPaths() {
  const courses = await getCollection("courses");
  return courses
    .filter((c) => c.data.status === "live" && c.data.quiz)
    .map((c) => {
      const ref = c.data.vendor;
      const vendorSlug = typeof ref === "string" ? ref : ref?.id;
      return {
        params: { vendor: vendorSlug, level: c.data.level },
        props: { course: c },
      };
    });
}

const { course } = Astro.props;
const { vendor: vendorParam, level } = Astro.params;

const vendors = await getCollection("vendors");
const vendor = vendors.find((v) => v.data.slug === vendorParam)!;

const levelLabel: Record<string, string> = {
  l1: "Beginner",
  l2: "Intermediate",
  l3: "Advanced",
};
---

<BaseLayout
  title={`${vendor.data.name} ${levelLabel[level]} — Final quiz`}
  description={`Test your understanding of ${course.data.title}.`}
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-8">
    <Breadcrumb
      items={[
        { href: "/", label: "Home" },
        { href: "/vendors/", label: "Vendors" },
        { href: `/vendors/${vendor.data.slug}/`, label: vendor.data.name },
        {
          href: `/vendors/${vendor.data.slug}/${level}/`,
          label: levelLabel[level],
        },
        { label: "Final quiz" },
      ]}
    />

    <header class="mt-6 mb-2">
      <Badge variant={level as "l1" | "l2" | "l3"} className="mb-3 text-[10px] uppercase tracking-widest">
        {levelLabel[level]} · Final quiz
      </Badge>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
        {course.data.title} — final check
      </h1>
      <p class="mt-3 max-w-2xl text-muted-foreground text-lg leading-relaxed">
        Wrong answers explain themselves on the spot. Your best score is
        remembered locally — nothing leaves your browser.
      </p>
    </header>

    <Quiz slug={course.data.quiz!} client:visible />
  </div>
</BaseLayout>
